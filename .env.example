# Vouchsafe environment — copy to .env and fill locally. NEVER commit real keys.

# --- Coston2 deployer (chain id 114) ---
# Fund via faucet: https://faucet.flare.network/coston2
PRIVATE_KEY=
# Optional Flare RPC api key (tracer endpoint); leave blank to use public RPC
FLARE_RPC_API_KEY=
# Optional Blockscout explorer key for contract verification
FLARE_EXPLORER_API_KEY=

# --- Deployed contract addresses (filled after deploy) ---
SOLVENCY_REGISTRY_ADDRESS=
ATTESTOR_STAKING_ADDRESS=
SOLVENCY_VERIFIER_ADDRESS=

# --- TEE extension (Phase 2) ---
# Simulated mode uses a local ECDSA key standing in for the enclave key.
# Real Confidential Space (MODE=0) generates + holds this key inside the enclave.
TEE_SIGNER_PRIVATE_KEY=
SIMULATED_TEE=true
# MODE=0 = production attestation (FTDC-accepted); MODE=1 = simulated attestation
MODE=1
TEE_EXTENSION_PORT=7800

# --- FDC verifier + DA layer (Phase 3) ---
VERIFIER_URL_TESTNET=
VERIFIER_API_KEY_TESTNET=00000000-0000-0000-0000-000000000000
COSTON2_DA_LAYER_URL=

# --- Attestor service (Phase 4) ---
ATTESTOR_SERVICE_PORT=7900
